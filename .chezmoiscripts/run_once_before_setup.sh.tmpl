#!/usr/bin/env bash

set -e
set -u
set -o pipefail
set -C

LOCAL_DIR=/usr/local
HOME_LOCAL_DIR=$HOME/.local
GIST_BASE_URL="https://gist.githubusercontent.com/holly/"
AWS_INSTALL_CMD_URL="$GIST_BASE_URL/7ed983b00af2c6c8df8a8c49449bbc35/raw/aws_install_ctrl.sh"
FISH_INSTALL_CMD_URL="$GIST_BASE_URL/2bd195b9e72b2978d2d3e95102f51fd7/raw/fish_install.sh"
NVIM_INSTALL_CMD_URL="$GIST_BASE_URL/cd5fdfb0c8e08f48dbaba071b1b58909/raw/nvim_install.sh"
ROOT_INSTALL_CMD_URLS=($AWS_INSTALL_CMD_URL $FISH_INSTALL_CMD_URL $NVIM_INSTALL_CMD_URL)

TOOLS_INSTALL_CMD_URL="$GIST_BASE_URL/fdab4bade1955de90467ce72b586d02d/raw/tools_install.py"

{{- if eq .chezmoi.os "linux" }}
echo "dnf install"
sudo dnf -y groupinstall "Development Tools"
sudo dnf -y install xsel git ca-certificates  epel-release jq
echo ""
{{- end }}

for url in "${ROOT_INSTALL_CMD_URLS[@]}"; do
    fname=$(basename "$url")
    install_path="${LOCAL_DIR}/bin/$fname"

    echo "install $fname from $url"
    sudo bash -c "curl -sfL -o $install_path $url; chmod +x $install_path; $install_path install; :"
    echo ""
done


fname=$(basename "$TOOLS_INSTALL_CMD_URL")
install_path="${HOME_LOCAL_DIR}/bin/$fname"

echo "install $fname from $TOOLS_INSTALL_CMD_URL"
curl -sfL -o $install_path $TOOLS_INSTALL_CMD_URL
chmod +x $install_path
$install_path
echo ""

echo "install bun"
curl -fsSL https://bun.sh/install | bash
echo ""

echo "install uv"
curl -LsSf https://astral.sh/uv/install.sh | sh
echo ""

