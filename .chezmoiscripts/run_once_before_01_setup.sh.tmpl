#!/usr/bin/env bash

set -e
set -u
set -o pipefail
set -C

LOCAL_DIR=/usr/local
HOME_LOCAL_DIR=$HOME/.local
GIST_BASE_URL="https://gist.githubusercontent.com/holly/"
AWS_INSTALL_CMD_URL="$GIST_BASE_URL/7ed983b00af2c6c8df8a8c49449bbc35/raw/aws_install_ctrl.sh"
FISH_INSTALL_CMD_URL="$GIST_BASE_URL/2bd195b9e72b2978d2d3e95102f51fd7/raw/fish_install.sh"
NVIM_INSTALL_CMD_URL="$GIST_BASE_URL/cd5fdfb0c8e08f48dbaba071b1b58909/raw/nvim_install.sh"
ROOT_INSTALL_CMD_URLS=($AWS_INSTALL_CMD_URL $FISH_INSTALL_CMD_URL $NVIM_INSTALL_CMD_URL)

BW_INSTALL_CMD_URL="$GIST_BASE_URL/e080372da4e8ca9aad7259540acd9077/raw/bitwarden_install.sh"
SHFMT_INSTALL_CMD_URL="$GIST_BASE_URL/933f4e9594fc3ee67a8cb8eadfb3077e/raw/shfmt_install.sh"

FISHER_SOURCE_URL="https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish"

{{- if eq .chezmoi.osRelease.idLike "rhel centos fedora" }}
echo "dnf install"
sudo dnf -y groupinstall "Development Tools"
sudo dnf -y install epel-release
sudo dnf -y update
sudo dnf -y install xsel git curl ca-certificates jq age unzip libatomic bind-utils glibc-langpack-ja ripgrep bat glow fd-find duf ShellCheck
{{ else if eq .chezmoi.osRelease.idLike "debian" }}
echo "apt install"

echo for glow install
sudo mkdir -p /etc/apt/keyrings
curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg
echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" | sudo tee /etc/apt/sources.list.d/charm.list

# eza install

sudo apt -y update
sudo apt -y install xsel build-essential git cmake pkg-config autotools-dev autoconf automake libtool clang llvm gdb valgrind git curl jq age unzip bind9-dnsutils libatomic1 ripgrep bat glow fd-find duf eza shellcheck 
{{- end }}
echo ""

for url in "${ROOT_INSTALL_CMD_URLS[@]}"; do
    fname=$(basename "$url")
    install_path="${LOCAL_DIR}/bin/$fname"

    echo "install $fname from $url"
    sudo bash -c "curl -sfL -o $install_path $url; chmod +x $install_path; $install_path install; :"
    echo ""
done

echo "install bitwarden cli"
bash -c "$(curl -sSfL $BW_INSTALL_CMD_URL)" -- install || :
echo

# install shfmt
echo "install shfmt cli"
bash -c "$(curl -sSfL $SHFMT_INSTALL_CMD_URL)" 
echo

echo "install claude"
curl -fsSL https://claude.ai/install.sh | bash
echo ""

echo "install bun"
curl -fsSL https://bun.sh/install | bash
echo ""

echo "install uv"
curl -LsSf https://astral.sh/uv/install.sh | sh
echo ""

echo "install volta"
curl https://get.volta.sh | bash   
echo ""

echo "install node by volta"
PATH="$PATH:$HOME/.volta/bin"
volta install node@latest
echo ""

# install fisher and more plugins
fish -c "curl -sfL $FISHER_SOURCE_URL | source; sleep 3 && fisher install jorgebucaran/fisher"
sleep 3
cat <<EOL | xargs -I% fish -c "fisher install %"
oh-my-fish/theme-bobthefish
laughedelic/fish_logo
jethrokuan/z
0rax/fish-bd
jethrokuan/fzf
EOL

# install  nvim plugin tools
PATH="$PATH:$HOME/.bun/bin"
cat <<EOL | xargs bun add -g 
tree-sitter-cli
pyright
bash-language-server
@vtsls/language-server
git-cz
EOL

